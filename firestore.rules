rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net - Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.keys().size() == 5 && // uid, email, displayName, photoURL, createdAt
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt == request.time;
    }

    function isValidAudit(data) {
      return data.keys().hasAll(['userId', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.status in ['pending', 'processing', 'completed'] &&
             data.createdAt == request.time;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['auditId', 'userId', 'type', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      isValidId(userId) &&
                      isValidUser(incoming()) && 
                      incoming().uid == existing().uid &&
                      incoming().createdAt == existing().createdAt;
    }

    match /audits/{auditId} {
      allow get: if isSignedIn() && isOwner(existing().userId) && isValidId(auditId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidAudit(incoming()) && isValidId(auditId);
      allow update: if isSignedIn() && 
                      isOwner(existing().userId) && 
                      isValidId(auditId) &&
                      isValidAudit(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt && (
                        // Logic defined per action if needed, otherwise allow generic owner updates
                        incoming().diff(existing()).affectedKeys().hasAny(['status', 'fairnessScore', 'biasDetectedCount', 'complianceStatus'])
                      );
    }

    match /reports/{reportId} {
      allow get: if isSignedIn() && isOwner(existing().userId) && isValidId(reportId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidReport(incoming()) && isValidId(reportId);
      // Reports are typically immutable
      allow update: if false;
      allow delete: if isSignedIn() && isOwner(existing().userId) && isValidId(reportId);
    }
  }
}
